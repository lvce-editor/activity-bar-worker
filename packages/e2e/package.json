{
  "name": "e2e",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "e2e": "node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. && node ./scripts/e2e-custom-view-icons.js",
    "e2e:firefox": "npm run patch:playwright-firefox-worker-websocket && node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=firefox && node ./scripts/e2e-custom-view-icons.js --browser=firefox",
    "e2e:firefox:headless": "npm run patch:playwright-firefox-worker-websocket && node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=firefox --headless && node ./scripts/e2e-custom-view-icons.js --browser=firefox --headless",
    "e2e:headless": "node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --headless && node ./scripts/e2e-custom-view-icons.js --headless",
    "e2e:webkit": "node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=webkit && node ./scripts/e2e-custom-view-icons.js --browser=webkit",
    "e2e:webkit:headless": "node ./node_modules/@lvce-editor/test-with-playwright/bin/test-with-playwright.js --only-extension=. --test-path=. --browser=webkit --headless && node ./scripts/e2e-custom-view-icons.js --browser=webkit --headless",
    "patch:playwright-firefox-worker-websocket": "node ./scripts/patch-playwright-firefox-worker-websocket.js",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@lvce-editor/test-with-playwright": "^22.1.0"
  }
}
