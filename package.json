{
  "name": "@lvce-editor/activity-bar-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "node packages/build/src/build-watch.ts",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "e2e:webkit": "cd packages/e2e && npm run e2e:webkit",
    "e2e:webkit:headless": "cd packages/e2e && npm run e2e:webkit:headless",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "node --experimental-strip-types packages/build/src/measureMemory.ts",
    "test": "lerna run test",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^17.0.0",
    "eslint": "^10.7.0",
    "knip": "^6.27.0",
    "lerna": "^8.2.4",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
