{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "exclude": ["exports", "types"],
  "ignore": [
    "packages/activity-bar-worker/src/parts/ContextMenuOptions/ContextMenuOptions.ts",
    "packages/activity-bar-worker/src/parts/GetHiddenItems/GetHiddenItems.ts",
    "packages/activity-bar-worker/src/parts/GetVisibleActivityBarItems/GetVisibleActivityBarItems.ts",
    "packages/activity-bar-worker/src/parts/VisibleItem/VisibleItem.ts"
  ],
  "workspaces": {
    ".": {
      "project": ["*.js"],
      "ignoreDependencies": ["@lerna/legacy-package-management"]
    },
    "packages/activity-bar-worker": {
      "entry": ["src/activityBarWorkerMain.ts", "test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/build": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@babel/preset-typescript", "@lvce-editor/verror", "esbuild", "playwright"]
    },
    "packages/e2e": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/server": {
      "project": ["src/**/*.js"]
    }
  }
}
